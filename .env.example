DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=Asia/Kolkata

# Leave false to use zero-config SQLite (db.sqlite3, created automatically).
# Set true once you've run mysql_setup.sql to switch to real MySQL.
USE_MYSQL=False

DB_NAME=aegis_db
DB_USER=aegis_user
DB_PASSWORD=changeme
DB_HOST=127.0.0.1
DB_PORT=3306

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
